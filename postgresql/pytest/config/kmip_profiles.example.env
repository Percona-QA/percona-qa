# KMIP revalidation profiles — copy and source per lab server.
# See docs/kmip_revalidation.md and lib/kmip_profiles.py
#
# Select profiles for pytest:
#   export KMIP_REVALIDATE_PROFILES=pykmip_docker
#   export KMIP_REVALIDATE_PROFILES=fortanix,thales
#   export KMIP_REVALIDATE_PROFILES=all

# ── pykmip_docker (CI) — filled by scripts/setup_kmip_for_pytest.sh ─────────
# export KMIP_SERVER_ADDRESS=127.0.0.1
# export KMIP_SERVER_PORT=5696
# export KMIP_CLIENT_CA=/tmp/certs/client_cert.pem
# export KMIP_CLIENT_KEY=/tmp/certs/client_key.pem
# export KMIP_SERVER_CA=/tmp/certs/server_ca.pem

# ── Fortanix DSM ─────────────────────────────────────────────────────────────
# export KMIP_FORTANIX_HOST=kmip.example.fortanix.com
# export KMIP_FORTANIX_PORT=5696
# export KMIP_FORTANIX_CLIENT_CERT=/path/to/client.pem
# export KMIP_FORTANIX_CLIENT_KEY=/path/to/client-key.pem
# export KMIP_FORTANIX_SERVER_CA=/path/to/ca.pem

# ── Thales CipherTrust Manager ─────────────────────────────────────────────────
# export KMIP_THALES_HOST=kmip.ciphertrust.example
# export KMIP_THALES_PORT=5696
# export KMIP_THALES_CLIENT_CERT=/path/to/client.pem
# export KMIP_THALES_CLIENT_KEY=/path/to/client-key.pem
# export KMIP_THALES_SERVER_CA=/path/to/ca.pem

# ── Cosmian KMS ───────────────────────────────────────────────────────────────
# export KMIP_COSMIAN_HOST=127.0.0.1
# export KMIP_COSMIAN_PORT=9998
# export KMIP_COSMIAN_CLIENT_CERT=/path/to/client.pem
# export KMIP_COSMIAN_CLIENT_KEY=/path/to/client-key.pem
# export KMIP_COSMIAN_SERVER_CA=/path/to/ca.pem

# ── Akeyless ──────────────────────────────────────────────────────────────────
# export KMIP_AKEYLESS_HOST=kmip.akeyless.example
# export KMIP_AKEYLESS_PORT=5696
# export KMIP_AKEYLESS_CLIENT_CERT=/path/to/client.pem
# export KMIP_AKEYLESS_CLIENT_KEY=/path/to/client-key.pem
# export KMIP_AKEYLESS_SERVER_CA=/path/to/ca.pem
