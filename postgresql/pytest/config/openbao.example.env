# OpenBao pytest — copy and export for a remote lab server.
# See docs/vault.md and scripts/setup_openbao_for_pytest.sh
#
# Local dev (recommended):
#   ./scripts/install_openbao.sh
#   source scripts/setup_openbao_for_pytest.sh

# export VAULT_ADDR=http://127.0.0.1:8200
# export VAULT_TOKEN_FILE=/tmp/pg_tde_pytest_openbao/bao_root_token
# export VAULT_SECRET_MOUNT=pg_tde
# export VAULT_NAMESPACE=pg_tde_ns1/
# export OPENBAO_BIN=/usr/bin/bao
# export VAULT_KV_ONLY_TOKEN_FILE=/tmp/pg_tde_pytest_openbao/token_kv_only
