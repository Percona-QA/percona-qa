# HashiCorp Vault Enterprise — pg_tde revalidation environment
#
# Copy and customize, then:
#   cd postgresql/pytest
#   source scripts/config/hashicorp_vault.example.env   # or your copy
#   ./scripts/run_hashicorp_vault_revalidation.sh
#
# Prerequisites on the host:
#   - Vault unsealed, namespaces + KV mount configured
#   - pg_tde installed (set INSTALL_DIR)
#   - For KMIP: Vault KMIP engine listening + client certs on disk

# ── PostgreSQL ───────────────────────────────────────────────────────────────
export INSTALL_DIR="${INSTALL_DIR:-/usr/lib/postgresql/18}"
export PORT="${PORT:-5433}"
export PGUSER="${PGUSER:-$(id -un)}"
export RUN_DIR="${RUN_DIR:-/tmp/pg_tde_hashicorp_vault}"
export PGDATA="${PGDATA:-${RUN_DIR}/data}"

# Set to 1 to use an already-running cluster (skip initdb/start/stop).
# export HC_VAULT_USE_EXISTING_PG=1
# export PORT=5432

# ── Vault KV v2 (namespaced) ─────────────────────────────────────────────────
export VAULT_ADDR="${VAULT_ADDR:-http://127.0.0.1:8200}"
export VAULT_SECRET_MOUNT="${VAULT_SECRET_MOUNT:-pg_tde}"
export VAULT_NAMESPACE="${VAULT_NAMESPACE:-ns1/}"   # trailing slash for pg_tde SQL
export VAULT_TOKEN_FILE="${VAULT_TOKEN_FILE:-/tmp/token_ent}"
# Leave empty for plain HTTP (NULL in SQL):
export VAULT_CA_PATH="${VAULT_CA_PATH:-}"

# Optional second namespace for cross-namespace smoke (enable scenario 8):
# export VAULT_NAMESPACE2="${VAULT_NAMESPACE2:-ns2/}"
# export VAULT_TOKEN_FILE2="${VAULT_TOKEN_FILE2:-/tmp/token_ent_ns2}"

# Root token for creating kv-only policy tokens (PG-1959 scenario):
# export VAULT_ROOT_TOKEN="${VAULT_ROOT_TOKEN:-hvs....}"

# ── Vault KMIP engine (Enterprise) ───────────────────────────────────────────
export KMIP_VAULT_HOST="${KMIP_VAULT_HOST:-127.0.0.1}"
export KMIP_VAULT_PORT="${KMIP_VAULT_PORT:-5696}"
export KMIP_VAULT_CLIENT_CERT="${KMIP_VAULT_CLIENT_CERT:-/tmp/client_cert.pem}"
export KMIP_VAULT_CLIENT_KEY="${KMIP_VAULT_CLIENT_KEY:-/tmp/client_key.pem}"
export KMIP_VAULT_SERVER_CA="${KMIP_VAULT_SERVER_CA:-/tmp/server_cert.pem}"

# Set to 1 after pg_tde Register -2 is fixed; otherwise create_key xfail is OK.
# export VAULT_KMIP_REQUIRE_REGISTER_SUCCESS=1

# Which suites to run (all | kv | kmip):
# export HC_VAULT_SUITES=all
